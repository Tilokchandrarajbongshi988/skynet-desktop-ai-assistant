{
  "appId": "com.skynet.desktop",
  "productName": "Skynet",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron",
    "dist-react",
    "package.json"
  ],
  "extraResources": [
    "dist-electron/preload.cjs",
    {
      "from": "node_modules/sql.js/dist/sql-wasm.wasm",
      "to": "sql.js/sql-wasm.wasm"
    }
  ],
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  },
  "win": {
    "icon": "desktopIcon.png",
    "target": [
      "nsis",
      "portable"
    ]
  },
  "nsis": {
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "runAfterFinish": true
  },
  "portable": {
    "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
  }
}
