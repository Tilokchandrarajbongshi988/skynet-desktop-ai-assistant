{
  "appId": "com.luna.desktop",
  "productName": "Luna",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron",
    "dist-react",
    "package.json"
  ],
  "extraResources": ["dist-electron/preload.cjs"],
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  },
  "win": {
    "icon": "desktopIcon.png",
    "target": [
      "nsis",
      "portable"
    ]
  },
  "nsis": {
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  },
  "portable": {
    "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
  }
}
